FROM flashrt:5090

RUN pip install --quiet --no-cache-dir fastapi uvicorn 'transformers<4.56'

COPY serving/ /workspace/FlashRT/serving/
WORKDIR /workspace/FlashRT

EXPOSE 8000

# Lightweight liveness check: GET /health returns {"status":"ok"} without
# running GPU inference. If the server process crashes (CUDA error, OOM),
# Docker's --restart always restarts the container. The previous
# decode-speed healthcheck was removed because it accumulated KV cache
# sessions that filled VRAM and caused the restarts it was trying to prevent.
HEALTHCHECK --interval=60s --timeout=10s --start-period=90s --retries=2 \
    CMD python3 -c "import urllib.request; urllib.request.urlopen('http://localhost:8000/health', timeout=5)" || exit 1

CMD ["python3", "-m", "serving.qwen36_agent.server", "--checkpoint", "/nvfp4", "--max-seq", "196608", "--route-min-seq", "0", "--default-max-tokens", "8192", "--max-output-tokens", "65536", "--host", "0.0.0.0", "--port", "8000"]
