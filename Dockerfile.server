# FlashRT Qwen3.6 server image.
#
# Base: `flashrt:5090` (or the older `flashrt-base:5090` alias, see below)
# This must be a complete FlashRT kernel image (CUTLASS, FA2, FlashRT
# kernels) that the build server can COPY serving/ files into.
#
# Base image convention (READ THIS before rebuilding):
#   The "real" base image is built from docker/Dockerfile (--tag flashrt:5090).
#   It is a ~30GB image containing the kernel binaries and is normally
#   built once and cached.
#
#   When only the server code changes (this Dockerfile), we don't rebuild
#   the full base — we layer the serving code on top. To keep the
#   FROM line working, we tag the most recent flashrt-server:5090 as
#   flashrt:5090 after each build (the build_server.sh helper does this).
#
#   This works because the COPY serving/ below re-installs the same files
#   we already have — only the CMD layer is unique per build. Both the
#   base and the server end up sharing the bulk of the layers.
#
# If you have a fresh machine with no flashrt:5090 base:
#   docker build -t flashrt:5090 -f docker/Dockerfile .   (~25 min cold)
#   Then build this Dockerfile as normal.
#
# If you only have the existing flashrt-server:5090 (typical case after
# a previous build), the build_server.sh helper handles the retag for you.

FROM flashrt:5090

RUN pip install --quiet --no-cache-dir fastapi uvicorn 'transformers<4.56'

COPY serving/ /workspace/FlashRT/serving/
WORKDIR /workspace/FlashRT

EXPOSE 8000

# Lightweight liveness check: GET /health returns {"status":"ok"} without
# running GPU inference. If the server process crashes (CUDA error, OOM),
# Docker's --restart always restarts the container. The previous
# decode-speed healthcheck was removed because it accumulated KV cache
# sessions that filled VRAM and caused the restarts it was trying to prevent.
HEALTHCHECK --interval=60s --timeout=10s --start-period=90s --retries=2 \
    CMD python3 -c "import urllib.request; urllib.request.urlopen('http://localhost:8000/health', timeout=5)" || exit 1

CMD ["python3", "-m", "serving.qwen36_agent.server", "--checkpoint", "/nvfp4", "--max-seq", "196608", "--route-min-seq", "0", "--default-max-tokens", "32768", "--max-output-tokens", "65536", "--host", "0.0.0.0", "--port", "8000"]
